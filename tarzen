#!/bin/bash
set -euo pipefail

VERSION="1.0.0"
INSTALL_LOCATION="/usr/local/bin/tarzen"
REPO_RAW="https://raw.githubusercontent.com/mxskeen/tarzen/main/tarzen"

get_target_home() {
    if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
        getent passwd "$SUDO_USER" | cut -d: -f6
    else
        echo "$HOME"
    fi
}

REGISTRY_DIR="$(get_target_home)/.local/share/tarzen/registry"
LEGACY_REGISTRY_DIR="/root/.local/share/tarzen/registry"

COLOR_RED=$'\033[0;31m'
COLOR_GREEN=$'\033[0;32m'
COLOR_YELLOW=$'\033[1;33m'
COLOR_CYAN=$'\033[0;36m'
COLOR_BOLD=$'\033[1m'
COLOR_RESET=$'\033[0m'

# ─── Helpers ───────────────────────────────────────────────────────────────────

info()  { printf "%b\n" "${COLOR_CYAN}[INFO]${COLOR_RESET} $*"; }
ok()    { printf "%b\n" "${COLOR_GREEN}[OK]${COLOR_RESET} $*"; }
warn()  { printf "%b\n" "${COLOR_YELLOW}[WARN]${COLOR_RESET} $*"; }
err()   { printf "%b\n" "${COLOR_RED}[ERROR]${COLOR_RESET} $*" >&2; }
bold()  { printf "%b\n" "${COLOR_BOLD}$*${COLOR_RESET}"; }

confirm() {
    local prompt="$1"
    while true; do
        read -rp "$(printf "%b" "${COLOR_BOLD}${prompt} (Y/N): ${COLOR_RESET}")" answer < /dev/tty
        case "$answer" in
            [Yy]) return 0 ;;
            [Nn]) return 1 ;;
            *) echo "Please press Y or N." ;;
        esac
    done
}

ensure_registry() {
    mkdir -p "$REGISTRY_DIR"
}

# ─── Self-Install ─────────────────────────────────────────────────────────────
# When piped via curl (bash <(curl ...) or curl | sudo bash),
# the script is not running from disk. Detect that and install itself.

cmd_self_install() {
    # Already installed?
    if [[ -f "$INSTALL_LOCATION" ]] && cmp -s "$0" "$INSTALL_LOCATION" 2>/dev/null; then
        ok "tarzen is already installed at $INSTALL_LOCATION"
        return 0
    fi

    info "Installing tarzen to $INSTALL_LOCATION..."

    # Find our own source — could be /dev/stdin, /tmp/..., or a real file
    local self_source="$0"

    # If piped via curl | bash, $0 is typically /dev/stdin or bash
    # In that case, re-download from GitHub
    if [[ "$self_source" == /dev/* ]] || [[ ! -f "$self_source" ]]; then
        info "Downloaded via pipe — fetching from GitHub..."
        if ! curl -fL "$REPO_RAW" -o "$INSTALL_LOCATION" 2>/dev/null; then
            err "Failed to download tarzen from GitHub."
            err "Try: sudo bash tarzen --self-install"
            return 1
        fi
    else
        # Running from a real file — just copy it
        cp "$self_source" "$INSTALL_LOCATION"
    fi

    chmod +x "$INSTALL_LOCATION"

    # Verify
    if command -v tarzen &>/dev/null; then
        ok "tarzen installed successfully!"
        echo ""
        echo "  Usage:"
        echo "    sudo tarzen install ./app.tar.xz"
        echo "    sudo tarzen install https://example.com/app.tar.xz"
        echo "    tarzen list"
        echo "    sudo tarzen uninstall <app-name>"
        echo ""
    else
        warn "Installed to $INSTALL_LOCATION but not in PATH."
        warn "Add /usr/local/bin to your PATH or restart your terminal."
    fi
}

cmd_self_uninstall() {
    if [[ -f "$INSTALL_LOCATION" ]]; then
        rm -f "$INSTALL_LOCATION"
        ok "tarzen removed from $INSTALL_LOCATION"
    else
        warn "tarzen not found at $INSTALL_LOCATION"
    fi

    if [[ -d "${HOME}/.local/share/tarzen" ]]; then
        if confirm "Remove tarzen registry (~/.local/share/tarzen)?"; then
            rm -rf "${HOME}/.local/share/tarzen"
            ok "Registry removed."
        fi
    fi

    ok "tarzen uninstalled."
}

# ─── Distro Detection ─────────────────────────────────────────────────────────

detect_distro() {
    if [[ -f /etc/os-release ]]; then
        # shellcheck disable=SC1091
        source /etc/os-release
        echo "${ID:-unknown}"
    elif [[ -f /etc/redhat-release ]]; then
        echo "rhel"
    elif [[ -f /etc/arch-release ]]; then
        echo "arch"
    elif [[ -f /etc/debian_version ]]; then
        echo "debian"
    else
        echo "unknown"
    fi
}

detect_pkg_manager() {
    local distro="$1"
    case "$distro" in
        ubuntu|debian|linuxmint|pop|elementary)
            echo "apt" ;;
        fedora|rhel|centos|rocky|alma)
            echo "dnf" ;;
        arch|manjaro|endeavouros|garuda)
            echo "pacman" ;;
        opensuse*|suse)
            echo "zypper" ;;
        alpine)
            echo "apk" ;;
        void)
            echo "xbps" ;;
        gentoo)
            echo "emerge" ;;
        nixos)
            echo "nix" ;;
        *)
            echo "unknown" ;;
    esac
}

show_system_info() {
    local distro
    distro=$(detect_distro)
    local pkg_mgr
    pkg_mgr=$(detect_pkg_manager "$distro")

    if [[ -f /etc/os-release ]]; then
        # shellcheck disable=SC1091
        source /etc/os-release
        bold "System: ${PRETTY_NAME:-$distro}"
    else
        bold "System: $distro"
    fi
    bold "Package manager: $pkg_mgr"
    bold "Architecture: $(uname -m)"
}

# ─── Content Detection ─────────────────────────────────────────────────────────

detect_content_type() {
    local dir="$1"

    # Nested packages first
    if find "$dir" -maxdepth 2 -name "*.deb" -print -quit | grep -q .; then
        echo "deb"; return
    fi
    if find "$dir" -maxdepth 2 -name "*.rpm" -print -quit | grep -q .; then
        echo "rpm"; return
    fi

    # AppImage
    if find "$dir" -maxdepth 3 -type f -name "*.AppImage" -print -quit | grep -q .; then
        echo "appimage"; return
    fi

    # Source builds
    if find "$dir" -maxdepth 3 -name "CMakeLists.txt" -print -quit | grep -q .; then
        echo "source-cmake"; return
    fi
    if find "$dir" -maxdepth 3 -name "meson.build" -print -quit | grep -q .; then
        echo "source-meson"; return
    fi
    if find "$dir" -maxdepth 3 -name "configure" -type f -print -quit | grep -q .; then
        echo "source-autotools"; return
    fi
    if find "$dir" -maxdepth 3 -name "Makefile" -print -quit | grep -q .; then
        echo "source-make"; return
    fi
    if find "$dir" -maxdepth 3 -name "cargo.toml" -print -quit | grep -q .; then
        echo "source-cargo"; return
    fi
    if find "$dir" -maxdepth 3 -name "go.mod" -print -quit | grep -q .; then
        echo "source-go"; return
    fi

    # Pre-built binary: ELF executables
    if find "$dir" -maxdepth 3 -type f -executable -print0 2>/dev/null \
        | xargs -0 file 2>/dev/null \
        | grep -qi "ELF.*executable"; then
        echo "binary"; return
    fi

    # Fallback: any executable files
    if find "$dir" -maxdepth 3 -type f -executable -print -quit | grep -q .; then
        echo "binary-guess"; return
    fi

    echo "unknown"
}

find_app_icon() {
    local src_dir="$1"
    local app_id="$2"

    local icon_path=""
    icon_path=$(find "$src_dir" -maxdepth 5 -type f \( -iname "*.png" -o -iname "*.svg" -o -iname "*.xpm" \) \
        | grep -i -E "(icon|logo|${app_id})" | head -1 || true)

    if [[ -z "$icon_path" ]]; then
        icon_path=$(find "$src_dir" -maxdepth 5 -type f \( -iname "*.png" -o -iname "*.svg" -o -iname "*.xpm" \) | head -1 || true)
    fi

    if [[ -z "$icon_path" ]]; then
        icon_path=$(find "$src_dir" -maxdepth 5 -type f -iname "*.ico" | head -1 || true)
    fi

    echo "$icon_path"
}

stage_app_icon() {
    local icon_src="$1"
    local target_dir="$2"
    local app_id="$3"

    if [[ -z "$icon_src" || ! -f "$icon_src" ]]; then
        echo ""
        return 0
    fi

    mkdir -p "$target_dir"

    local icon_ext
    icon_ext="${icon_src##*.}"
    local icon_dest="${target_dir}/${app_id}.${icon_ext}"

    cp "$icon_src" "$icon_dest"
    echo "$icon_dest"
}

refresh_desktop_caches() {
    if command -v update-desktop-database &>/dev/null; then
        update-desktop-database /usr/share/applications >/dev/null 2>&1 || true
    fi

    if command -v gtk-update-icon-cache &>/dev/null; then
        gtk-update-icon-cache -f -t /usr/share/icons/hicolor >/dev/null 2>&1 || true
    fi
}

post_install_note() {
    local app_name="$1"
    echo ""
    info "If the app icon does not appear in search yet, log out and back in once."
    info "You can also restart the desktop shell or re-open the app launcher."
    ok "$app_name is installed."
}

# ─── Install Functions ─────────────────────────────────────────────────────────

install_binary() {
 local src_dir="$1"
 local app_name="$2"

 # Find the main executable
 local main_exe=""
 local exe_name=""
 local install_dir=""

 # First: check if executable matches app_name in root
 if [[ -f "$src_dir/$app_name" ]] && file "$src_dir/$app_name" | grep -qi "ELF.*executable"; then
   main_exe="$src_dir/$app_name"
   exe_name="$app_name"
   install_dir="$src_dir"
 fi

 # Second: check for any ELF executable in root directory
 if [[ -z "$main_exe" ]]; then
   while IFS= read -r -d '' f; do
     if file "$f" | grep -qi "ELF.*executable"; then
       main_exe="$f"
       exe_name=$(basename "$f")
       install_dir="$src_dir"
       break
     fi
   done < <(find "$src_dir" -maxdepth 1 -type f -executable -print0 2>/dev/null)
 fi

 # Third: check in subdirectories
 if [[ -z "$main_exe" ]]; then
   while IFS= read -r -d '' f; do
     if file "$f" | grep -qi "ELF.*executable"; then
       main_exe="$f"
       exe_name=$(basename "$f")
       # Get the parent directory as install_dir
       install_dir=$(dirname "$f")
       break
     fi
   done < <(find "$src_dir" -maxdepth 3 -type f -executable -print0 2>/dev/null)
 fi

 if [[ -z "$main_exe" ]]; then
   err "Could not find a main executable in the archive."
   err "The archive may need manual installation. Contents:"
   find "$src_dir" -maxdepth 3 -type f -executable 2>/dev/null | head -20
   return 1
 fi

 local opt_name="${exe_name%.*}"
 if [[ -z "$opt_name" ]]; then
   opt_name="$app_name"
 fi

 info "Installing to /opt/$opt_name..."
 rm -rf "/opt/$opt_name"
 mkdir -p "/opt/$opt_name"

 # If executable was in root, copy files; otherwise move the subdirectory
 if [[ "$install_dir" == "$src_dir" ]]; then
   cp -r "$src_dir"/* "/opt/$opt_name/" 2>/dev/null || true
   cp -r "$src_dir"/.[!.]* "/opt/$opt_name/" 2>/dev/null || true
 else
   mv "$install_dir" "/opt/$opt_name/"
 fi

 info "Linking binary to /usr/local/bin/$exe_name..."
 ln -sf "/opt/$opt_name/$(basename "$main_exe")" "/usr/local/bin/$exe_name"

 local desktop_name
 desktop_name=$(echo "$opt_name" | sed 's/.*/\u&/')

 local icon_src icon_path
 icon_src=$(find_app_icon "$src_dir" "$opt_name")
 icon_path=$(stage_app_icon "$icon_src" "/usr/share/icons/hicolor/256x256/apps" "$opt_name")

 local desktop_icon=""
 if [[ -n "$icon_path" ]]; then
     desktop_icon="$opt_name"
 fi

 create_desktop_entry "$opt_name" "$desktop_name" "/opt/$opt_name/$(basename "$main_exe")" "$desktop_icon"

 register_install "$opt_name" "binary" "/opt/$opt_name" "/usr/local/bin/$exe_name" "$exe_name"
 refresh_desktop_caches
 ok "Installed $desktop_name!"
 ok "Run with: $exe_name"
 post_install_note "$desktop_name"
}

install_appimage() {
    local src_dir="$1"
    local app_name="$2"

    local appimage_file
    appimage_file=$(find "$src_dir" -maxdepth 3 -type f -name "*.AppImage" | head -1)

    if [[ -z "$appimage_file" ]]; then
        err "No .AppImage file found."; return 1
    fi

    local exe_name
    exe_name=$(basename "$appimage_file")
    local opt_name="${exe_name%.AppImage}"

    info "Installing AppImage to /opt/$opt_name/..."
    mkdir -p "/opt/$opt_name"
    cp "$appimage_file" "/opt/$opt_name/$exe_name"
    chmod +x "/opt/$opt_name/$exe_name"

    info "Linking to /usr/local/bin/$opt_name..."
    ln -sf "/opt/$opt_name/$exe_name" "/usr/local/bin/$opt_name"

    local icon_src icon_path
    icon_src=$(find_app_icon "$src_dir" "$opt_name")
    icon_path=$(stage_app_icon "$icon_src" "/usr/share/icons/hicolor/256x256/apps" "$opt_name")

    local desktop_icon=""
    if [[ -n "$icon_path" ]]; then
        desktop_icon="$opt_name"
    fi

    create_desktop_entry "$opt_name" "$opt_name" "/opt/$opt_name/$exe_name" "$desktop_icon"

    register_install "$opt_name" "appimage" "/opt/$opt_name" "/usr/local/bin/$opt_name" "$opt_name"
    refresh_desktop_caches
    ok "Installed $opt_name!"
    ok "Run with: $opt_name"
    post_install_note "$opt_name"
}

install_deb() {
    local src_dir="$1"
    local app_name="$2"

    local distro
    distro=$(detect_distro)
    local pkg_mgr
    pkg_mgr=$(detect_pkg_manager "$distro")

    local deb_files
    deb_files=$(find "$src_dir" -maxdepth 2 -name "*.deb")

    if [[ -z "$deb_files" ]]; then
        err "No .deb files found."; return 1
    fi

    case "$pkg_mgr" in
        apt)
            info "Installing .deb packages via apt..."
            echo "$deb_files" | xargs apt install -y
            ;;
        *)
            warn "Not a Debian-based system. Trying dpkg..."
            echo "$deb_files" | xargs dpkg -i
            apt-get install -f -y 2>/dev/null || true
            ;;
    esac

    register_install "$app_name" "deb" "" "" ""
    ok "Installed .deb packages!"
}

install_rpm() {
    local src_dir="$1"
    local app_name="$2"

    local distro
    distro=$(detect_distro)
    local pkg_mgr
    pkg_mgr=$(detect_pkg_manager "$distro")

    local rpm_files
    rpm_files=$(find "$src_dir" -maxdepth 2 -name "*.rpm")

    if [[ -z "$rpm_files" ]]; then
        err "No .rpm files found."; return 1
    fi

    case "$pkg_mgr" in
        dnf)
            info "Installing .rpm packages via dnf..."
            echo "$rpm_files" | xargs dnf install -y
            ;;
        zypper)
            info "Installing .rpm packages via zypper..."
            echo "$rpm_files" | xargs zypper install -y --no-confirm
            ;;
        *)
            warn "Not an RPM-based system. Trying rpm directly..."
            echo "$rpm_files" | xargs rpm -Uvh --nodeps
            ;;
    esac

    register_install "$app_name" "rpm" "" "" ""
    ok "Installed .rpm packages!"
}

install_source() {
    local src_dir="$1"
    local app_name="$2"
    local build_type="$3"

    local build_dir
    build_dir=$(find "$src_dir" -maxdepth 1 -type d ! -path "$src_dir" | head -1)
    if [[ -z "$build_dir" ]]; then
        build_dir="$src_dir"
    fi

    info "Building from source ($build_type)..."

    case "$build_type" in
        source-cmake)
            mkdir -p "$build_dir/build"
            cd "$build_dir/build"
            cmake ..
            make -j"$(nproc)"
            make install
            cd - >/dev/null
            ;;
        source-make)
            cd "$build_dir"
            make -j"$(nproc)"
            make install
            cd - >/dev/null
            ;;
        source-autotools)
            cd "$build_dir"
            ./configure
            make -j"$(nproc)"
            make install
            cd - >/dev/null
            ;;
        source-meson)
            cd "$build_dir"
            meson setup build
            cd build
            ninja
            ninja install
            cd - >/dev/null
            ;;
        source-cargo)
            cd "$build_dir"
            cargo build --release
            cargo install --path .
            cd - >/dev/null
            ;;
        source-go)
            cd "$build_dir"
            go build ./...
            go install ./...
            cd - >/dev/null
            ;;
        *)
            err "Unknown build system: $build_type"; return 1
            ;;
    esac

    register_install "$app_name" "$build_type" "" "" ""
    ok "Built and installed from source!"
}

# ─── Desktop Entry ─────────────────────────────────────────────────────────────

create_desktop_entry() {
    local app_id="$1"
    local display_name="$2"
    local exec_path="$3"
    local icon_path="$4"

    local icon_line="Icon=application-x-executable"
    if [[ -n "$icon_path" ]]; then
        icon_line="Icon=$icon_path"
    fi

    info "Creating desktop entry..."
    cat > "/usr/share/applications/${app_id}.desktop" <<EOF
[Desktop Entry]
Name=$display_name
Comment=Installed via tarzen
Exec=$exec_path
$icon_line
Terminal=false
Type=Application
Categories=Utility;
EOF
}

# ─── Registry ──────────────────────────────────────────────────────────────────

register_install() {
    local app_name="$1"
    local install_type="$2"
    local install_path="$3"
    local symlink_path="$4"
    local exe_name="$5"

    ensure_registry

    cat > "${REGISTRY_DIR}/${app_name}.json" <<EOF
{
    "name": "$app_name",
    "type": "$install_type",
    "install_path": "$install_path",
    "symlink_path": "$symlink_path",
    "exe_name": "$exe_name",
    "installed_at": "$(date -Iseconds)"
}
EOF
}

# ─── Uninstall App ──────────────────────────────────────────────────────────────

cmd_uninstall() {
    local app_name="$1"
    local reg_file="${REGISTRY_DIR}/${app_name}.json"

    if [[ ! -f "$reg_file" ]]; then
        err "No registry entry found for '$app_name'."
        echo ""
        info "Installed apps:"
        list_installed
        return 1
    fi

    local install_type install_path symlink_path exe_name
    install_type=$(grep '"type"' "$reg_file" | cut -d'"' -f4)
    install_path=$(grep '"install_path"' "$reg_file" | cut -d'"' -f4)
    symlink_path=$(grep '"symlink_path"' "$reg_file" | cut -d'"' -f4)
    exe_name=$(grep '"exe_name"' "$reg_file" | cut -d'"' -f4)

    info "Uninstalling $app_name ($install_type)..."

    if ! confirm "Remove $app_name?"; then
        echo "Cancelled."; return 0
    fi

    case "$install_type" in
        binary|appimage)
            if [[ -n "$install_path" && -d "$install_path" ]]; then
                info "Removing $install_path..."
                rm -rf "$install_path"
            fi
            if [[ -n "$symlink_path" && -L "$symlink_path" ]]; then
                info "Removing symlink $symlink_path..."
                rm -f "$symlink_path"
            fi
            ;;
        deb)
            warn ".deb packages were installed via package manager."
            warn "Use your package manager to remove them."
            ;;
        rpm)
            warn ".rpm packages were installed via package manager."
            warn "Use your package manager to remove them."
            ;;
        source-*)
            warn "Source-built packages were installed via make/meson."
            warn "You may need to manually remove installed files."
            ;;
    esac

    if [[ -f "/usr/share/applications/${app_name}.desktop" ]]; then
        rm -f "/usr/share/applications/${app_name}.desktop"
        info "Removed desktop entry."
    fi

    rm -f "$reg_file"
    ok "$app_name uninstalled."
}

list_installed() {
    ensure_registry

    local registry_dirs=("$REGISTRY_DIR")
    if [[ "$REGISTRY_DIR" != "$LEGACY_REGISTRY_DIR" && -d "$LEGACY_REGISTRY_DIR" ]]; then
        registry_dirs+=("$LEGACY_REGISTRY_DIR")
    fi

    local found_any=0
    for dir in "${registry_dirs[@]}"; do
        [[ -d "$dir" ]] || continue
        for reg_file in "$dir"/*.json; do
            [[ -f "$reg_file" ]] || continue
            found_any=1
            local name type installed_at
            name=$(grep '"name"' "$reg_file" | cut -d'"' -f4)
            type=$(grep '"type"' "$reg_file" | cut -d'"' -f4)
            installed_at=$(grep '"installed_at"' "$reg_file" | cut -d'"' -f4)
            printf "%b\n" "  ${COLOR_BOLD}${name}${COLOR_RESET}  (${type})  — installed ${installed_at}"
        done
    done

    if [[ "$found_any" -eq 0 ]]; then
        echo "  No apps installed via tarzen."
    fi
}

# ─── Main Install Flow ─────────────────────────────────────────────────────────

cmd_install() {
    local input="$1"

    local distro pkg_mgr
    distro=$(detect_distro)
    pkg_mgr=$(detect_pkg_manager "$distro")

    echo ""
    bold "═══ tarzen installer ═══"
    echo ""
    show_system_info
    echo ""

    # Resolve input: URL or local file
    local tar_file=""
    local tmp_dir=""

    if [[ "$input" == http://* || "$input" == https://* ]]; then
        info "Downloading from URL..."
        tmp_dir=$(mktemp -d)
        trap 'rm -rf "$tmp_dir"' EXIT
        curl -fL "$input" -o "$tmp_dir/archive.tar.xz"
        tar_file="$tmp_dir/archive.tar.xz"
    elif [[ -f "$input" ]]; then
        tar_file=$(realpath "$input")
    else
        err "File not found: $input"
        exit 1
    fi

 # Validate extension and detect compression type
 local compression_type="xz"
 if echo "$tar_file" | grep -qiE "\.tar\.gz$|\.tgz$"; then
   compression_type="gz"
 elif echo "$tar_file" | grep -qiE "\.tar\.xz$|\.txz$"; then
   compression_type="xz"
 else
   warn "File doesn't have .tar.xz or .tar.gz extension. Attempting to extract anyway..."
 fi

 # Extract
 local extract_dir
 extract_dir=$(mktemp -d)

 # Cleanup function that handles both tmp_dir and extract_dir
 cleanup() {
   [[ -n "${tmp_dir:-}" && -d "$tmp_dir" ]] && rm -rf "$tmp_dir"
    [[ -n "${extract_dir:-}" && -d "$extract_dir" ]] && rm -rf "$extract_dir"
 }
 trap cleanup EXIT


 # Use appropriate tar flag based on compression type
 if [[ "$compression_type" == "gz" ]]; then
   if ! tar -xzf "$tar_file" -C "$extract_dir"; then
     err "Extraction failed. Is this a valid archive?"
     exit 1
   fi
 else
   if ! tar -xJf "$tar_file" -C "$extract_dir"; then
     err "Extraction failed. Is this a valid .tar.xz file?"
     exit 1
   fi
 fi

    echo ""
    info "Archive contents:"
    find "$extract_dir" -maxdepth 2 -type f | sed "s|$extract_dir/||" | head -30
    echo ""

    # Determine app name
    local app_name
 app_name=$(basename "$tar_file" | sed -E 's/\.(tar\.xz|txz|tar\.gz|tgz)$//' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
    info "App name: $app_name"

    # Detect content type
    local content_type
    content_type=$(detect_content_type "$extract_dir")
    info "Detected content type: $content_type"
    echo ""

    # Confirm
    if ! confirm "Install $app_name ($content_type)?"; then
        echo "Cancelled."; return 0
    fi

    # Need root for install
    if [[ $EUID -ne 0 ]]; then
        err "Installation requires root. Re-run with sudo."
        exit 1
    fi

    # Install based on type
    case "$content_type" in
        binary|binary-guess)
            install_binary "$extract_dir" "$app_name"
            ;;
        appimage)
            install_appimage "$extract_dir" "$app_name"
            ;;
        deb)
            install_deb "$extract_dir" "$app_name"
            ;;
        rpm)
            install_rpm "$extract_dir" "$app_name"
            ;;
        source-make|source-cmake|source-autotools|source-meson|source-cargo|source-go)
            install_source "$extract_dir" "$app_name" "$content_type"
            ;;
        *)
            err "Could not determine how to install this archive."
            echo ""
            info "Contents:"
            find "$extract_dir" -maxdepth 3 | sed "s|$extract_dir/||"
            echo ""
            warn "You may need to install this manually."
            return 1
            ;;
    esac
}

# ─── CLI ───────────────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
${COLOR_BOLD}tarzen${COLOR_RESET} v${VERSION} — Universal tar.xz installer

${COLOR_BOLD}INSTALL${COLOR_RESET}
    curl -sL ${REPO_RAW} | sudo bash

${COLOR_BOLD}USAGE${COLOR_RESET}
    tarzen install <path-or-url>     Install from a .tar.xz file or URL
    tarzen uninstall <app-name>      Uninstall an app installed via tarzen
    tarzen list                      List apps installed via tarzen
    tarzen info                      Show system/distro info

${COLOR_BOLD}SELF-MANAGEMENT${COLOR_RESET}
    tarzen --self-install            Install/update tarzen itself
    tarzen --self-uninstall          Remove tarzen from system

${COLOR_BOLD}EXAMPLES${COLOR_RESET}
    sudo tarzen install ./firefox.tar.xz
    sudo tarzen install https://example.com/app.tar.xz
    tarzen list
    sudo tarzen uninstall firefox

EOF
}

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        install|i)
            if [[ -z "${1:-}" ]]; then
                err "Provide a .tar.xz file path or URL."
                echo ""; usage; exit 1
            fi
            cmd_install "$1"
            ;;
        uninstall|remove|rm)
            if [[ -z "${1:-}" ]]; then
                err "Provide an app name to uninstall."
                echo ""; info "Installed apps:"; list_installed; exit 1
            fi
            cmd_uninstall "$1"
            ;;
        list|ls)
            list_installed
            ;;
        info)
            show_system_info
            ;;
        --self-install)
            cmd_self_install
            ;;
        --self-uninstall)
            cmd_self_uninstall
            ;;
        help|--help|-h)
            usage
            ;;
        *)
            # ─── Self-install when piped via curl ────────────────────────
            # If no known command and script is running from a pipe/stdin,
            # the user probably did: curl | sudo bash  → install tarzen itself
            if [[ -z "$cmd" ]]; then
                usage
            else
                err "Unknown command: $cmd"
                usage
                exit 1
            fi
            ;;
    esac
}

# ─── Entry Point ───────────────────────────────────────────────────────────────
# When piped via curl (curl | sudo bash), $0 is /dev/stdin or similar.
# Detect that and auto-run self-install instead of showing usage.

if [[ "$0" == /dev/* ]] || [[ ! -f "$0" ]]; then
    # Running from pipe — install tarzen
    cmd_self_install
else
    main "$@"
fi
